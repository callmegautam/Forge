{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "worker": "bun run src/worker/runner.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@forge/auth": "workspace:*",
    "@forge/db": "workspace:*",
    "@forge/env": "workspace:*",
    "better-auth": "catalog:",
    "cors": "^2.8.5",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "socket.io": "^4.8.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@forge/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
