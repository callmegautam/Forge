{
  "name": "forge",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "better-auth": "1.6.11",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @forge/db db:push",
    "db:studio": "turbo -F @forge/db db:studio",
    "db:generate": "turbo -F @forge/db db:generate",
    "db:migrate": "turbo -F @forge/db db:migrate",
    "db:start": "turbo -F @forge/db db:start",
    "db:watch": "turbo -F @forge/db db:watch",
    "db:stop": "turbo -F @forge/db db:stop",
    "db:down": "turbo -F @forge/db db:down"
  },
  "dependencies": {
    "@forge/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@forge/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
